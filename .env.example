# ============================================
# AQI Predictor - Environment Variables
# ============================================
# Copy this file to .env and fill in your keys
# NEVER commit .env to GitHub!

# OpenWeather API Key (Free tier works!)
# Get it at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Your city for AQI prediction
CITY_NAME=Lahore
COUNTRY_CODE=PK

# (Optional) AQICN API Key - Free at https://aqicn.org/api/
AQICN_API_KEY=your_aqicn_api_key_here
